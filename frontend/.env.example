# ── Backend API ─────────────────────────────────────────────────────────────
# Server-side (used by Next.js Route Handlers — NOT exposed to browser)
BACKEND_URL=http://localhost:8000

# ── Client-side public vars ──────────────────────────────────────────────────
# NEXT_PUBLIC_* variables are bundled into the browser JS.
# Only expose non-sensitive URLs here. Never put API keys or secrets.

# WebSocket URL for live transcript streaming (Phase 3)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=KoyalAI
NEXT_PUBLIC_APP_VERSION=0.1.0

# ── Notes ────────────────────────────────────────────────────────────────────
# In Phase 8 (Kubernetes):
#   BACKEND_URL=http://koyal-backend-svc.koyal-ai.svc.cluster.local:8000
#   NEXT_PUBLIC_WS_URL=wss://api.koyal.internal  (nginx WebSocket proxy)