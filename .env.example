# ─── Sarvam AI 
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── Groq 
GROQ_API_KEY=your_groq_api_key_here

# ─── Qdrant 
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_TIMEOUT_SECONDS=30

# ─── Redis 
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── LLM config 
GROQ_MODEL_NAME=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT=30

# ── Sarvam global 
SARVAM_TIMEOUT=5
SARVAM_MAX_RETRIES=3
SARVAM_BACKOFF_BASE=2.0

# ── STT 
STT_MODEL=saaras:v2
STT_TIMEOUT=15
STT_MAX_RETRIES=3
STT_BACKOFF_BASE=2.0
STT_CONFIDENCE_THRESHOLD=0.4

# ── TTS 
TTS_MODEL=bulbul:v1
TTS_TIMEOUT=10
TTS_MAX_RETRIES=3
TTS_BACKOFF_BASE=2.0
TTS_PACE=1.0
TTS_SAMPLE_RATE=16000
TTS_MAX_CHARS_PER_CHUNK=500

# ── VAD 
VAD_AGGRESSIVENESS=2
VAD_SAMPLE_RATE=16000
VAD_FRAME_DURATION_MS=30
VAD_SPEECH_THRESHOLD=8
VAD_SILENCE_THRESHOLD=25
VAD_MIN_SPEECH_FRAMES=5
VAD_ENERGY_THRESHOLD=200.0

# ── Session 
SESSION_TIMEOUT_SECONDS=300
MAX_CONCURRENT_SESSIONS=100

# ── Outbound 
OUTBOUND_MAX_CONCURRENT=5

# ── Cost rates (₹) 
STT_COST_PER_MINUTE=0.50
TTS_COST_PER_CHAR=0.0015
LLM_COST_PER_TOKEN=0.0
COST_KEY_TTL_DAYS=30

# ── WebSocket 
WS_RECEIVE_TIMEOUT=0.1
WS_GREETING_ENABLED=true

# ─── Langfuse
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=http://localhost:3001

LANGFUSE_BASE_URL=http://localhost:3001

LANGFUSE_ENCRYPTION_KEY=koyal-ai-secret-change-in-production
LANGFUSE_NEXTAUTH_SECRET=koyal-ai-secret-change-in-production
LANGFUSE_SALT=koyal-ai-secret-change-in-production

LANGFUSE_INIT_ORG_ID=koyalai-org
LANGFUSE_INIT_ORG_NAME=KoyalAI
LANGFUSE_INIT_PROJECT_ID=koyalai-project
LANGFUSE_INIT_PROJECT_NAME=KoyalAI Production
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-koyalai-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-koyalai-local
LANGFUSE_INIT_USER_EMAIL=admin@koyalai.io
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=koyalai2026admin

LANGFUSE_FLUSH_AT=20
LANGFUSE_FLUSH_INTERVAL=500

# ─── MinIO (local S3 for Langfuse v3 event storage) 
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret

# ─── LiveKit 
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_SIP_TRUNK_ID=trunk_in_1

# ─── App 
APP_ENV=development
DEFAULT_LANGUAGE=hi-IN
SUPPORTED_LANGUAGES=hi-IN,en-IN,mr-IN,ta-IN,te-IN,kn-IN,bn-IN
