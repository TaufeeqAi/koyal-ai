# ─── Sarvam AI (free tier — signup at app.sarvam.ai, no credit card needed) ───
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── Groq (free tier — console.groq.com) ────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Qdrant (local Docker — Phase 1) ─────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Redis (cost tracking — used from Phase 3 onward) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Langfuse (self-hosted — Phase 4) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=http://localhost:3001

# ─── LiveKit (Phase 6) ────────────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_SIP_TRUNK_ID=trunk_in_1

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEFAULT_LANGUAGE=hi-IN
SUPPORTED_LANGUAGES=hi-IN,en-IN,mr-IN,ta-IN,te-IN,kn-IN,bn-IN
